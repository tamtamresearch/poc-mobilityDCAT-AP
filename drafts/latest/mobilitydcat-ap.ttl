  adms:versionNotes "Version 3.0.0 extends DCAT-AP v3.0.0, adds DatasetSeries, aligns with geoDCAT-AP v3.0.0, and includes new properties for Dataset and Distribution."@en ;
  dcat:distribution [ a adms:AssetDistribution ;
      dcterms:format <http://publications.europa.eu/resource/authority/file-type/RDF_XML>,
        <http://www.w3.org/ns/formats/data/RDF_XML> ;
      dcterms:title "RDF/XML"@en ;
      dcat:downloadURL <https://w3id.org/mobilitydcat-ap/drafts/latest/mobilitydcat-ap.rdf> ;
